{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .gemini/hooks/session-start.py",
            "timeout": 10000
          }
        ]
      }
    ],
    "BeforeAgent": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "python3 .gemini/hooks/inject-workflow-state.py",
            "timeout": 5000
          }
        ]
      }
    ]
  }
}
