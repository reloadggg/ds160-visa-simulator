page {
  min-height: 100%;
  background: #f8fafc;
  color: #0f172a;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
}

button {
  border-radius: 16rpx;
}

.safe-area-page {
  box-sizing: border-box;
  min-height: 100vh;
  padding: 32rpx 28rpx calc(32rpx + env(safe-area-inset-bottom));
}
