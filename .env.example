OPENAI_BASE_URL=https://your-openai-compatible-endpoint/v1
OPENAI_API_KEY=your-api-key
# 可选：默认会在检测到 OPENAI_* 配置时自动启用多模态材料抽取。
# 仅在你明确想禁用图片/PDF 的模型识别时再设置为 false。
# MULTIMODAL_EXTRACTION_ENABLED=false

# 允许本地 Next.js 前端访问 FastAPI。
# 多个来源以逗号分隔。
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# 可选：数据库连接。默认使用当前目录 app.sqlite3；Docker 镜像默认使用 /data/app.sqlite3。
DATABASE_URL=sqlite:///./app.sqlite3

# 可选：服务器测试环境的简单进入鉴权。
# 留空时关闭鉴权；设置后，前端先 POST /v1/auth/login 换取 Bearer token，
# 再通过 Authorization: Bearer <token> 访问业务接口。
APP_AUTH_PASSWORD=
APP_AUTH_TOKEN_TTL_SECONDS=86400

# 可选：允许前端用户填写自己的 OpenAI-compatible Base URL / API Key / Model。
# 开启后，后端仍会保存聊天、材料和报告；API Key 只随请求使用，不写入数据库。
ALLOW_USER_MODEL_CONFIG=false
ALLOW_USER_MODEL_STREAMING=false

# runtime 以 .env 为主，default.yaml 只做兜底。
RUNTIME_DEFAULT_PROVIDER=openai_compatible
RUNTIME_DEFAULT_MODEL=gpt-5.4

# 需要兼容旧 runtime key 的 provider 时，可单独覆盖。
RUNTIME_SCORING_ENGINE_INTERVIEW_TURN_PROVIDER=openai
RUNTIME_SCORING_ENGINE_INTERVIEW_TURN_REASONING_EFFORT=xhigh

RUNTIME_EXTRACTOR_SERVICE_GATE_REVIEW_PROVIDER=openai
RUNTIME_EXTRACTOR_SERVICE_GATE_REVIEW_REASONING_EFFORT=xhigh

RUNTIME_SCORING_AGENT_INTERVIEW_TURN_PROVIDER=openai_compatible
RUNTIME_SCORING_AGENT_INTERVIEW_TURN_REASONING_EFFORT=xhigh

RUNTIME_EXTRACTOR_AGENT_INTERVIEW_TURN_PROVIDER=openai_compatible
RUNTIME_EXTRACTOR_AGENT_INTERVIEW_TURN_REASONING_EFFORT=xhigh

RUNTIME_QUESTION_AGENT_INTERVIEW_TURN_PROVIDER=openai_compatible
RUNTIME_QUESTION_AGENT_INTERVIEW_TURN_REASONING_EFFORT=high

# 可选：美签政策 RAG。默认关闭；开启前先运行资料 ingestion 生成 Chroma 索引。
RAG_ENABLED=false
RAG_VECTOR_STORE=chroma
RAG_INDEX_VERSION=v1
RAG_CHROMA_MODE=persistent
RAG_CHROMA_PATH=./data/chroma/us_visa
RAG_CHROMA_HOST=localhost
RAG_CHROMA_PORT=8000
RAG_CHROMA_SSL=false
RAG_COLLECTION_PREFIX=us_visa

# 硅基流动 Embedding / Rerank。API Key 不要提交到仓库。
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_API_KEY=
SILICONFLOW_EMBEDDING_MODEL=BAAI/bge-m3
SILICONFLOW_EMBEDDING_DIMENSIONS=
SILICONFLOW_EMBEDDING_BATCH_SIZE=32
SILICONFLOW_RERANK_MODEL=Qwen/Qwen3-Reranker-4B

# RAG 检索参数。第三方资料默认只做研发参考，不进入事实回答。
RAG_VECTOR_TOP_K_PER_COLLECTION=8
RAG_CANDIDATE_LIMIT=24
RAG_RERANK_TOP_N=6
RAG_MIN_FINAL_SCORE=0.15
RAG_MAX_CONTEXT_CHARS=5000
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=150
RAG_UPLOAD_MAX_SIZE_MB=32
RAG_ALLOW_THIRD_PARTY_REFERENCE=false
RAG_SOURCE_MANIFEST=docs/superpowers/research/2026-05-21-us-visa-rag-source-manifest-100plus.md
RAG_RAW_DOC_DIR=data/rag/us_visa/raw
