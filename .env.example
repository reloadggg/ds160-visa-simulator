OPENAI_BASE_URL=https://your-openai-compatible-endpoint/v1
OPENAI_API_KEY=your-api-key
OPENAI_TIMEOUT_SECONDS=60
# 兼容网关若按客户端识别，可改为 codex-cli/0.50.0 等；默认 curl 便于排障。
OPENAI_COMPAT_USER_AGENT=curl/8.5.0
# 练习材料生成：分片（规划 + 逐文档）后，单次 LLM 调用超时（秒）。
AI_MATERIAL_BUNDLE_TIMEOUT_SECONDS=90
# 单份文档 / 中文摘要的 max_tokens 上限（降低不稳定网关长输出断连）。
# AI_MATERIAL_DOC_MAX_TOKENS=1600
# AI_MATERIAL_SUMMARY_MAX_TOKENS=500
# 连接/超时错误时的额外重试次数（不含首次）。
# AI_MATERIAL_GENERATION_MAX_RETRIES=2

# 日志默认输出 JSON，便于按 session_id / run_id / turn_id / document_id 串联线上问题。
LOG_LEVEL=INFO
LOG_FORMAT=json

# 可选：默认会在检测到 OPENAI_* 配置时自动启用多模态材料抽取。
# 仅在你明确想禁用图片/PDF 的模型识别时再设置为 false。
# MULTIMODAL_EXTRACTION_ENABLED=false

# 允许本地 Next.js 前端访问 FastAPI。
# 多个来源以逗号分隔。
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# 可选：本地直接运行 FastAPI 的数据库连接。
# 本地不设置则默认使用 sqlite:///./app.sqlite3。
# Docker Compose 会忽略这里的 DATABASE_URL，并通过 COMPOSE_DATABASE_URL
# 控制容器内 DATABASE_URL，避免本地 SQLite 配置污染生产 compose。
# DATABASE_URL=sqlite:///./app.sqlite3

# 可选：服务器测试环境访问保护。
# 留空时关闭鉴权；设置后，前端先 POST /v1/auth/login 建立服务端会话，
# 后端通过 HttpOnly Cookie 保护业务接口，不再把长期 token 暴露给浏览器 JS。
APP_AUTH_PASSWORD=
APP_AUTH_SESSION_TTL_SECONDS=86400
APP_AUTH_IDLE_TIMEOUT_SECONDS=28800
APP_AUTH_COOKIE_SECURE=true
APP_AUTH_COOKIE_SAMESITE=lax
APP_AUTH_PROTECT_DOCS=true
# 可选：OpenAI-compatible /v1/chat/completions 的机器调用 token。
# Web UI 使用 Cookie 会话；外部客户端如需直连该入口，应单独配置此 token。
# 机器 token 在 compat 路由上等价于 admin 的 session 访问权限，但仍应只部署给可信调用方。
APP_COMPAT_API_KEY=

# 可信代理：是否信任客户端/边缘传入的代理 IP 头（登录限流与审计）。
# 默认 false：只用直连 TCP peer（request.client.host），忽略 X-Forwarded-For、
# X-Real-IP 以及 CF-Connecting-IP，避免伪造头绕过 rate limit。
# 仅当应用位于会覆写/追加这些头的反代之后、且源站不对公网开放时再设为 true。
# true 时解析顺序：CF-Connecting-IP → 右端 X-Forwarded-For → X-Real-IP → 直连 peer。
# 生产在 Cloudflare 后：TRUST_X_FORWARDED_FOR=true，并限制源站仅接受 Cloudflare IP。
TRUST_X_FORWARDED_FOR=false

# 可选：允许前端用户填写自己的 OpenAI-compatible Base URL / API Key / Model。
# 开启后，后端仍会保存聊天、材料和报告；API Key 只随请求使用，不写入数据库。
ALLOW_USER_MODEL_CONFIG=false
ALLOW_USER_MODEL_STREAMING=false

# 可选：启用前端调试台的运行时快照接口。
ALLOW_RUNTIME_DEBUG=false

# 可选：发布版本标识。部署脚本可注入 git 短 SHA 和构建时间。
NEXT_PUBLIC_APP_VERSION=0.1.2
NEXT_PUBLIC_GIT_SHA=
NEXT_PUBLIC_BUILD_TIME=
APP_GIT_SHA=
APP_BUILD_TIME=

# Docker 部署默认使用 compose 内置 Postgres；需要外部数据库时再显式覆盖。
# COMPOSE_DATABASE_URL=postgresql+psycopg://ds160:ds160@postgres:5432/ds160
POSTGRES_USER=ds160
POSTGRES_PASSWORD=ds160
POSTGRES_DB=ds160

# runtime 以 .env 为主，default.yaml 只做兜底。
RUNTIME_DEFAULT_PROVIDER=openai_compatible
RUNTIME_DEFAULT_MODEL=gpt-5.4

# Agent runtime 切换。默认 native_interviewer 接管主流程。
# legacy 已废弃并会被忽略；graph / graph_shadow / graph_canary 当前也只是兼容标签，
# 不会切换公开 writer。公开响应 agent_runtime 恒为 native_interviewer；
# 配置值仅出现在 runtime_execution.configured_runtime（及 compatibility_runtime_label）。
AGENT_RUNTIME=native_interviewer
AGENT_RUNTIME_CANARY_PERCENT=0
AGENT_RUNTIME_TRACE_ENABLED=true

# Gate readiness: require material understanding completed (default true).
# Set false for offline demos where parsed/legacy evidence is enough.
MATERIAL_UNDERSTANDING_REQUIRED=true
AGENT_RUNTIME_TYPED_ADJUDICATION_ENABLED=true

# Practice/debug material-bundle generation guards (sliding windows + in-flight lock).
# Applied to both /practice/material-bundles* and /debug/material-bundles*.
# Session lock + per-session recent_starts live on SessionRecord.interviewer_state_json
# (material_generation); access-key counters are process-local (multi-worker needs shared store).
# Concurrent generate on same session → HTTP 409 "material generation already in progress…".
# Over limit → HTTP 429; seed_text over SEED_MAX_CHARS → HTTP 422 (request validation).
# MATERIAL_GENERATION_SESSION_LIMIT=5
# MATERIAL_GENERATION_SESSION_WINDOW_SECONDS=3600
# MATERIAL_GENERATION_ACCESS_KEY_LIMIT=20
# MATERIAL_GENERATION_ACCESS_KEY_WINDOW_SECONDS=3600
# MATERIAL_GENERATION_LOCK_TTL_SECONDS=900
# MATERIAL_GENERATION_SEED_MAX_CHARS=4000

# 需要兼容旧 runtime key 的 provider 时，可单独覆盖。
RUNTIME_SCORING_ENGINE_INTERVIEW_TURN_PROVIDER=openai
RUNTIME_SCORING_ENGINE_INTERVIEW_TURN_REASONING_EFFORT=xhigh

RUNTIME_EXTRACTOR_SERVICE_GATE_REVIEW_PROVIDER=openai
RUNTIME_EXTRACTOR_SERVICE_GATE_REVIEW_REASONING_EFFORT=xhigh

RUNTIME_SCORING_AGENT_INTERVIEW_TURN_PROVIDER=openai_compatible
RUNTIME_SCORING_AGENT_INTERVIEW_TURN_REASONING_EFFORT=xhigh

RUNTIME_EXTRACTOR_AGENT_INTERVIEW_TURN_PROVIDER=openai_compatible
RUNTIME_EXTRACTOR_AGENT_INTERVIEW_TURN_REASONING_EFFORT=xhigh

RUNTIME_QUESTION_AGENT_INTERVIEW_TURN_PROVIDER=openai_compatible
RUNTIME_QUESTION_AGENT_INTERVIEW_TURN_REASONING_EFFORT=high

# 可选：美签政策 RAG。默认关闭；开启前先运行资料 ingestion 生成 Chroma 索引。
RAG_ENABLED=false
RAG_VECTOR_STORE=chroma
RAG_INDEX_VERSION=v1
RAG_CHROMA_MODE=persistent
RAG_CHROMA_PATH=./data/chroma/us_visa
RAG_CHROMA_HOST=localhost
RAG_CHROMA_PORT=8000
RAG_CHROMA_SSL=false
RAG_COLLECTION_PREFIX=us_visa

# 硅基流动 Embedding / Rerank。API Key 不要提交到仓库。
SILICONFLOW_BASE_URL=https://api.siliconflow.cn/v1
SILICONFLOW_API_KEY=
SILICONFLOW_EMBEDDING_MODEL=BAAI/bge-m3
SILICONFLOW_EMBEDDING_DIMENSIONS=
SILICONFLOW_EMBEDDING_BATCH_SIZE=32
SILICONFLOW_RERANK_MODEL=Qwen/Qwen3-Reranker-4B

# RAG 检索参数。第三方资料默认只做研发参考，不进入事实回答。
RAG_VECTOR_TOP_K_PER_COLLECTION=8
RAG_CANDIDATE_LIMIT=24
RAG_RERANK_TOP_N=6
RAG_MIN_FINAL_SCORE=0.15
RAG_MAX_CONTEXT_CHARS=5000
RAG_CHUNK_SIZE=900
RAG_CHUNK_OVERLAP=150
RAG_UPLOAD_MAX_SIZE_MB=32
RAG_ALLOW_THIRD_PARTY_REFERENCE=false
RAG_SOURCE_MANIFEST=docs/rag/us-visa-source-manifest-100plus.md
RAG_RAW_DOC_DIR=data/rag/us_visa/raw
